{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "composite": true,
    "baseUrl": ".",
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "sourceMap": true,
    "strictNullChecks": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "@utils/*": ["./src/utils/*"],
      "@components/*": ["./src/components/*"],
      "@config": ["./src/config.ts"],
      "@/*": ["./src/*"]
    }
  },
  "ts-node": {
    "esm": true
  },
  "@hyperse/ts-node": {
    "esm": true
  },
  "include": [
    "src/**/*.ts",
    ".eslintrc.cjs"
  ]
}
