<main class="chat-page">
	<div class="chat-page__left-column">
		<div class="sidebar__header">
			{{{addChatButton}}}{{{viewProfile}}}
		</div>
		{{{sidebar}}}
	</div>
	<div class="chat-page__right-column">
			<div class="header-field">
				<div class="header-field__avatar">{{#if avatarHeadUrl}}<img id="avatar" alt="avatar" class='avatar-active' src="{{avatarHeadUrl}}" />{{/if}}</div>
				<div class="header-field__name">{{{chatName}}}</div>
				<div class="header-field__actions">
					{{#each activeChatButtons }}
						{{{activeChatButtons}}}
					{{/each}}
				</div>
				<div class="users-field">
					<span>Пользователи в чате: </span>
					{{#each userList}}
						{{{userList}}}
					{{/each}}
				</div>
			</div>
		{{{ activeChatWindow }}}
	</div>
	{{{addChatPopUp}}}
	{{{addUserToChatPopUp}}}
	{{{deleteChatPopUp}}}
</main>
