<div id={{popupId}} class="pop-up-window">
  <div class="pop-up-window__content">
	<h2>{{{title}}}</h2>
	    <form id={{formId}}>
			{{#each inputs}}
			  {{{inputs}}}
			{{/each}}
	        <div class="pop-up-window__content-buttons">
		        {{#each buttons}}
			        {{{buttons}}}
		        {{/each}}
	        </div>
	    </form>
  </div>
</div>
