{
  "name": "messenger-pr",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.12.0"
  },
  "targets": {
    "default": {
      "includeNodeModules": true
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "vite build && node server.cjs",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "lint:style": "stylelint \"**/*.scss\"",
    "lint:style:fix": "stylelint \"**/*.scss\" --fix",
    "lints": "npm run lint:fix && npm run lint:style:fix",
    "cleanup": "npm cache clean --force && rm -rf node_modules && npm install",
    "test": "mocha --experimental-specifier-resolution=node  --require ts-node/register --require tsconfig-paths/register  --require dotenv/config --recursive 'src/**/*.test.ts'",
    "prepare": "husky",
    "pre-commit": "npm run test && npm run lints"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run test && npm run lint"
    }
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/sinon": "^17.0.3",
    "@types/sinon-chai": "^3.2.12",
    "@yoichiro/vite-plugin-handlebars": "^1.4.0",
    "chai": "^6.2.2",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "mocha": "latest",
    "sass": "^1.97.1",
    "sinon-chai": "^4.0.0",
    "stylelint": "^17.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^7.0.1",
    "typescript": "^4.7.4",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^6.0.4",
    "@hyperse/ts-node": "^1.1.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "dotenv": "^17.3.1",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "express": "^5.2.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  },
  "dependencies": {
    "handlebars": "^4.7.8",
    "jsdom": "^28.1.0",
    "nanoid": "^5.1.6",
    "sinon": "^18.0.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "npx tsc --noEmit",
      "npx eslint",
      "npx prettier --check"
    ],
    "*.scss": [
      "npx stylelint"
    ]
  }
}
