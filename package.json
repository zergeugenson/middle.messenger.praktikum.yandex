{
  "name": "messenger-pr",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.12.0"
  },
  "targets": {
    "default": {
      "includeNodeModules": true
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "vite build && node server.cjs",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "lint:style": "stylelint \"**/*.scss\"",
    "lint:style:fix": "stylelint \"**/*.scss\" --fix"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/sinon": "^21.0.0",
    "@types/sinon-chai": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@yoichiro/vite-plugin-handlebars": "^1.4.0",
    "chai": "^6.2.2",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "mocha": "latest",
    "sass": "^1.97.1",
    "stylelint": "^17.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^7.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^6.0.4"
  },
  "dependencies": {
    "express": "^5.2.1",
    "handlebars": "^4.7.8",
    "jsdom": "^28.1.0",
    "nanoid": "^5.1.6",
    "sinon": "^21.0.1",
    "sinon-chai": "^4.0.1"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "npx tsc --noEmit",
      "npx eslint",
      "npx prettier --check"
    ],
    "*.scss": [
      "npx stylelint"
    ]
  }
}
