{
  "name": "messenger-pr",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.12.0"
  },
  "targets": {
    "default": {
      "includeNodeModules": true
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
